{
  "version": 4,
  "configurations": [
    {
      "name": "DACX Windows Runner",
      "intelliSenseMode": "windows-msvc-x64",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "defines": [
        "UNICODE",
        "_UNICODE"
      ],
      "includePath": [
        "${workspaceFolder}/windows",
        "${workspaceFolder}/windows/runner",
        "${workspaceFolder}/windows/flutter",
        "${workspaceFolder}/windows/flutter/ephemeral",
        "${workspaceFolder}/windows/flutter/ephemeral/cpp_client_wrapper/include",
        "${workspaceFolder}/windows/flutter/ephemeral/cpp_client_wrapper"
      ],
      "browse": {
        "limitSymbolsToIncludedHeaders": true,
        "path": [
          "${workspaceFolder}/windows",
          "${workspaceFolder}/windows/runner",
          "${workspaceFolder}/windows/flutter",
          "${workspaceFolder}/windows/flutter/ephemeral",
          "${workspaceFolder}/windows/flutter/ephemeral/cpp_client_wrapper/include",
          "${workspaceFolder}/windows/flutter/ephemeral/cpp_client_wrapper"
        ]
      }
    }
  ]
}
