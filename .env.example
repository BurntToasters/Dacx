GPG_KEY_ID=
GPG_PASSPHRASE=
GH_TOKEN=
GH_REPO_OWNER=BurntToasters
GH_REPO_NAME=Dacx
RELEASE_DOWNLOAD_BASE_URL=
RELEASE_NOTES=
RELEASE_PUB_DATE=
ALLOW_ASSET_REPLACE=false
AFTER_PACK_LOC=
APPLE_SIGNING_IDENTITY=
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
KEYCHAIN_PASSWORD=
DEVELOPER_DIR=
XCODE_DIR=
FLATPAK_MANIFEST=
FLATPAK_ARCH=
GH_TOKEN=

GPG_KEY_ID=
GPG_PASSPHRASE=

# macOS only
# Default when unset: /Applications/Xcode.app/Contents/Developer
XCODE_DIR=
SSH_USER_PWD=
APPLE_SIGNING_IDENTITY=
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=

# Windows only
# SHA-1 thumbprint of the Authenticode code-signing certificate in the
# Windows certificate store. Baked into builds as DACX_WINDOWS_SIGNER_THUMBPRINT.
WINDOWS_SIGNING_CERT_THUMBPRINT=
WINDOWS_SIGNTOOL_PATH=
WINDOWS_TIMESTAMP_URL=http://timestamp.digicert.com

# Windows updater manifest signing. Generate with:
#   node scripts/generate-update-key.js
# Keep private key secret. Commit only the generated public key in
# lib/services/update_trust_config.dart.
DACX_UPDATE_PRIVATE_KEY_PKCS8_BASE64=

# Optional: post-release mirror/copy location
AFTER_PACK_LOC=

# Linux only — path to appimagetool if not on PATH
# APPIMAGETOOL=/path/to/appimagetool

# ALLOW_ASSET_REPLACE=true

# GH_REPO_OWNER=BurntToasters
# GH_REPO_NAME=Dacx
