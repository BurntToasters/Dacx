GH_TOKEN=
GH_REPO_OWNER=BurntToasters
GH_REPO_NAME=Dacx

GPG_KEY_ID=
GPG_PASSPHRASE=

RELEASE_DOWNLOAD_BASE_URL=
RELEASE_NOTES=
RELEASE_PUB_DATE=
ALLOW_ASSET_REPLACE=false
AFTER_PACK_LOC=

# macOS only
# XCODE_DIR defaults to /Applications/Xcode.app when unset.
XCODE_DIR=
DEVELOPER_DIR=
APPLE_SIGNING_IDENTITY=
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=
# Optional. Use this for SSH/headless release builders or dedicated signing keychains.
KEYCHAIN_PATH=
KEYCHAIN_PASSWORD=
# Backwards-compatible alias used by older macOS builder setups.
SSH_USER_PWD=

# Windows only
# Authenticode signing via Azure Artifact Signing (Public Trust).
# AZURE_CLIENT_SECRET is secret; never commit real credentials.
# Once per Windows release VM (as Administrator), run: npm run setup:win:artifact-signing
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_CLIENT_SECRET=
AZURE_ARTIFACT_SIGNING_ENDPOINT=
AZURE_ARTIFACT_SIGNING_ACCOUNT=
AZURE_ARTIFACT_SIGNING_PROFILE=
AZURE_ARTIFACT_SIGNING_PUBLISHER=
# Only the exact value 1 permits an unsigned Windows build; missing or 0 enforces signing.
SKIP_WIN_CODESIGN=0
# Optional overrides if Client Tools are installed in a nonstandard location:
# AZURE_ARTIFACT_SIGNING_SIGNTOOL_PATH=
# AZURE_ARTIFACT_SIGNING_DLIB_PATH=

# Windows updater manifest signing. Generate with:
#   node scripts/generate-update-key.js
# Keep private key secret. Commit only the generated public key in
# lib/services/update_trust_config.dart.
DACX_UPDATE_PRIVATE_KEY_PKCS8_BASE64=

# Linux only
# APPIMAGETOOL=/path/to/appimagetool
FLATPAK_MANIFEST=
FLATPAK_ARCH=
