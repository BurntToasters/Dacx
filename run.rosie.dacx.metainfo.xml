<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>run.rosie.dacx</id>
  <name>Dacx</name>
  <summary>Quick, lightweight cross-platform media player</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>
  <developer id="run.rosie">
    <name>run.rosie</name>
  </developer>
  <description>
    <p>
      Dacx is a fast, lightweight media player for audio and video files.
      Built with Flutter and powered by libmpv, it supports a wide range of
      formats including MP3, FLAC, WAV, OGG, AAC, MP4, MKV, AVI, and WebM.
    </p>
    <p>
      Features include drag-and-drop file opening, keyboard shortcuts,
      playback speed control, and a clean minimal interface available in
      dark and light themes.
    </p>
  </description>
  <launchable type="desktop-id">dacx.desktop</launchable>
  <url type="homepage">https://github.com/BurntToasters/Dacx</url>
  <url type="bugtracker">https://github.com/BurntToasters/Dacx/issues</url>
  <url type="vcs-browser">https://github.com/BurntToasters/Dacx</url>
  <url type="help">https://help.rosie.run/dacx/en-us/faq</url>
  <url type="donation">https://rosie.run/support</url>
  <content_rating type="oars-1.1" />
  <categories>
    <category>AudioVideo</category>
    <category>Audio</category>
    <category>Video</category>
    <category>Player</category>
  </categories>
  <keywords>
    <keyword>music</keyword>
    <keyword>audio</keyword>
    <keyword>video</keyword>
    <keyword>media</keyword>
    <keyword>player</keyword>
    <keyword>mpv</keyword>
    <keyword>flutter</keyword>
  </keywords>
  <screenshots>
    <screenshot type="default">
      <caption>Dacx playing media with a clean dark interface</caption>
      <image>https://raw.githubusercontent.com/BurntToasters/Dacx/main/assets/screenshots/main.png</image>
    </screenshot>
  </screenshots>
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>
  <requires>
    <display_length compare="ge">480</display_length>
  </requires>
  <provides>
    <binary>dacx</binary>
    <mediatype>audio/mpeg</mediatype>
    <mediatype>audio/flac</mediatype>
    <mediatype>audio/wav</mediatype>
    <mediatype>audio/ogg</mediatype>
    <mediatype>audio/aac</mediatype>
    <mediatype>audio/x-m4a</mediatype>
    <mediatype>audio/opus</mediatype>
    <mediatype>video/mp4</mediatype>
    <mediatype>video/x-matroska</mediatype>
    <mediatype>video/webm</mediatype>
    <mediatype>video/quicktime</mediatype>
  </provides>
